APP_NAME=Roost

# Bind address. Default 127.0.0.1 = reachable ONLY from this machine (recommended).
# Setting 0.0.0.0 exposes the control API to your whole LAN with NO authentication —
# anyone on the network could disconnect devices. See SECURITY.md before changing.
HOST=127.0.0.1
PORT=5000

DEBUG=false
LOG_LEVEL=INFO

# How often to re-scan the network for devices (seconds).
SCAN_INTERVAL_SECONDS=30
